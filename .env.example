# =========================================================================
# MajiGuard Configuration Environment Variables
# Copy this file to .env and configure keys. Never commit the .env file.
# =========================================================================

# Option A: Gemini API via Google AI Studio (Recommended for local dev)
GEMINI_API_KEY=your_gemini_api_key_here

# Option B: Vertex AI Configuration (Used for deployment on GCP)
# Uncomment the lines below to switch from AI Studio to Vertex AI
# GOOGLE_GENAI_USE_VERTEXAI=true
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# GOOGLE_CLOUD_LOCATION=us-east1

# Optional CORS configuration (Comma-separated allowed origins)
# ALLOW_ORIGINS=http://localhost:5173,http://localhost:8000
ALLOW_ORIGINS=*
